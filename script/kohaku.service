[Unit]
Description=WebRTC Stats Collector Kohaku
After=network.target

[Service]
Restart=on-failure
RestartSec=60s
RestartPreventExitStatus=1
KillMode=control-group
User=kohaku
Group=kohaku
WorkingDirectory=/home/shiguredo/kohaku
ExecStart=/bin/bash -c '/home/shiguredo/kohaku/bin/kohaku -c /home/shiguredo/kohaku/config.ini 2>/var/log/kohaku/stderr.log 1>/var/log/kohaku/stdout.log'
Type=simple
LogsDirectory=kohaku

[Install]
WantedBy=multi-user.target
